# ============================================================
# Azure OpenAI / Azure AI Foundry
# ============================================================
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_FALLBACK_DEPLOYMENT=gpt-4-turbo

# ============================================================
# Azure Databricks
# ============================================================
DATABRICKS_HOST=https://adb-xxxxxxxxxxxxxxxxx.x.azuredatabricks.net
DATABRICKS_TOKEN=dapi-your-personal-access-token
DATABRICKS_CLUSTER_ID=your-cluster-id

# ============================================================
# LangSmith Observability
# ============================================================
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langsmith-api-key
LANGCHAIN_PROJECT=databricks-agent-monitor
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ============================================================
# Arize Phoenix (local OSS observability)
# ============================================================
PHOENIX_ENABLED=true
PHOENIX_HOST=localhost
PHOENIX_PORT=6006

# ============================================================
# Email Notification (SendGrid)
# ============================================================
SENDGRID_API_KEY=SG.your-sendgrid-api-key
EMAIL_FROM=alerts@yourcompany.com
EMAIL_TO=ops-team@yourcompany.com

# ============================================================
# Email Notification (Office365 fallback)
# ============================================================
O365_CLIENT_ID=your-client-id
O365_CLIENT_SECRET=your-client-secret
O365_TENANT_ID=your-tenant-id
O365_EMAIL_FROM=alerts@yourcompany.com

# ============================================================
# Scheduler
# ============================================================
SCHEDULER_INTERVAL_MINUTES=90
SCHEDULER_TEST_MODE=false   # Set true to trigger immediately

# ============================================================
# Application
# ============================================================
APP_ENV=local                # local | staging | production
LOG_LEVEL=INFO
DRY_RUN_MODE=true            # Safety: no real actions without flipping this
GRAPH_VERSION=1.0.0
PROMPT_VERSION=1.0.0
MODEL_NAME=gpt-4o

# ============================================================
# Persistence
# ============================================================
SQLITE_DB_PATH=./persistence_store/incidents.db
AUDIT_JSONL_PATH=./persistence_store/audit.jsonl
DEAD_LETTER_PATH=./persistence_store/dead_letter.jsonl

# ============================================================
# Security
# ============================================================
SECRET_MASK_PATTERNS=token,password,secret,api_key,Bearer
MAX_LOG_LINES=200
